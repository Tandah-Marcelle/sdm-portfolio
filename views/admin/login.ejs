<%- include('../layout-start') %>

    <section class="min-h-screen flex items-center justify-center px-6 bg-slate-950">
        <div class="max-w-md w-full">
            <div class="text-center mb-12">
                <div class="inline-block p-4 rounded-3xl bg-amber-500/5 border border-amber-500/20 mb-8">
                    <p class="text-xl font-extrabold tracking-tighter text-white">M.DONGMO<span
                            class="text-amber-500">.</span></p>
                </div>
                <h1 class="text-4xl font-extrabold text-white tracking-tighter mb-4">Command Portal<span
                        class="text-amber-500">.</span></h1>
                <p class="text-slate-500 font-medium text-sm mono tracking-widest uppercase">Restricted Technical Access
                </p>
            </div>

            <form action="/admin/login" method="POST"
                class="bg-slate-900 border border-slate-800 p-10 rounded-3xl shadow-2xl space-y-8">
                <div class="grid gap-3">
                    <label for="password"
                        class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Security
                        Credential</label>
                    <input type="password" id="password" name="password" required placeholder="Enter administrative key"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-amber-500 focus:ring-0 outline-none transition-all placeholder:text-slate-800">
                </div>

                <% if (typeof error !=='undefined' && error) { %>
                    <p class="text-red-500 text-[10px] font-bold uppercase tracking-widest text-center">
                        <%= error %>
                    </p>
                    <% } %>

                        <button type="submit"
                            class="w-full bg-amber-500 text-black py-6 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-amber-500/10">
                            Authenticate
                        </button>
            </form>

            <p class="text-center mt-12 text-[10px] font-bold text-slate-700 uppercase tracking-widest">
                Identity verification required for record modification
            </p>
        </div>
    </section>

    <%- include('../layout-end') %>