<%- include('../layout-start') %>

<section class="py-24 px-6 min-h-screen bg-slate-950">
    <div class="max-w-3xl mx-auto">
        <div class="mb-16">
            <a href="/admin" class="mono text-[10px] font-bold text-emerald-400 uppercase tracking-[0.3em] hover:text-white transition-all mb-8 inline-block">← Return to Command Center</a>
            <h1 class="text-6xl font-extrabold text-white tracking-tighter">Edit Project<span class="text-emerald-400">.</span></h1>
            <p class="text-slate-500 font-medium mt-4">Update the details for <span class="text-white"><%= project.title %></span>.</p>
        </div>

        <form action="/admin/projects/<%= project.id %>/edit" method="POST" enctype="multipart/form-data"
            class="space-y-10 bg-slate-900 border border-slate-800 p-12 rounded-3xl shadow-2xl">

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Project Title</label>
                <input type="text" name="title" required value="<%= project.title %>"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-cyan-500 outline-none transition-all">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Executive Summary</label>
                <textarea name="description" required rows="3"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all"><%= project.description %></textarea>
            </div>

            <!-- Image upload -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">
                    Project Image <span class="text-slate-700 normal-case tracking-normal font-normal">— upload a new file or keep the current one</span>
                </label>
                <!-- Current image preview -->
                <% if (project.image) { %>
                <div class="relative rounded-2xl overflow-hidden border border-slate-800 h-40">
                    <img src="<%= project.image %>" alt="Current image" class="w-full h-full object-cover opacity-60" id="image-preview">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="mono text-[10px] text-slate-500 uppercase tracking-widest bg-slate-950/80 px-3 py-1.5 rounded-full" id="image-label">Current Image</span>
                    </div>
                </div>
                <% } %>
                <label class="flex items-center gap-4 border border-dashed border-slate-700 rounded-2xl p-5 cursor-pointer hover:border-cyan-500 transition-all bg-slate-950 group">
                    <svg class="w-8 h-8 text-slate-700 group-hover:text-emerald-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <div>
                        <p class="text-slate-400 text-sm font-medium group-hover:text-white transition-colors">Click to replace image</p>
                        <p class="mono text-[10px] text-slate-700 uppercase tracking-widest mt-1">PNG, JPG, WEBP</p>
                    </div>
                    <input type="file" name="image" accept="image/*" class="hidden" id="image-input">
                </label>
                <!-- Keep current URL as fallback -->
                <input type="hidden" name="imageUrl" value="<%= project.image %>">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Tags <span class="text-slate-700 normal-case tracking-normal font-normal">(semicolon-separated)</span></label>
                <input type="text" name="tags" required value="<%= project.tags %>"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Technical Details</label>
                <textarea name="details" required rows="6"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all"><%= project.details %></textarea>
            </div>

            <div class="flex gap-4 pt-4">
                <button type="submit"
                    class="flex-1 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white hover:from-emerald-400 hover:to-cyan-400 border border-emerald-400/50 py-5 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-emerald-500/10">
                    Save Changes
                </button>
                <a href="/admin"
                    class="px-8 py-5 border border-slate-700 text-slate-400 rounded-full font-extrabold text-xs uppercase tracking-widest hover:border-slate-500 hover:text-white transition-all text-center">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>

<script>
    const input = document.getElementById('image-input');
    const preview = document.getElementById('image-preview');
    const label = document.getElementById('image-label');
    if (input) {
        input.addEventListener('change', () => {
            const file = input.files[0];
            if (!file) return;
            if (preview) { preview.src = URL.createObjectURL(file); preview.style.opacity = '1'; }
            if (label) label.textContent = 'New Image Selected';
        });
    }
</script>

<%- include('../layout-end') %>
