<%- include('../layout-start') %>

<section class="py-24 px-6 min-h-screen bg-slate-950">
    <div class="max-w-3xl mx-auto">
        <div class="mb-16">
            <a href="/admin" class="mono text-[10px] font-bold text-amber-500 uppercase tracking-[0.3em] hover:text-white transition-all mb-8 inline-block">← Return to Command Center</a>
            <h1 class="text-6xl font-extrabold text-white tracking-tighter">Add Case Study<span class="text-amber-500">.</span></h1>
            <p class="text-slate-500 font-medium mt-4">Document a new engineering milestone for the showcase.</p>
        </div>

        <form action="/admin/projects" method="POST" enctype="multipart/form-data"
            class="space-y-10 bg-slate-900 border border-slate-800 p-12 rounded-3xl shadow-2xl">

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Project Title</label>
                <input type="text" name="title" required placeholder="e.g. Charcoal Cocoa Dryer"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Executive Summary</label>
                <textarea name="description" required rows="3" placeholder="Brief overview for the project card..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700"></textarea>
            </div>

            <!-- Image upload -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">
                    Project Image <span class="text-slate-700 normal-case tracking-normal font-normal">— upload a file or paste a URL below</span>
                </label>
                <!-- File picker -->
                <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-slate-700 rounded-2xl cursor-pointer hover:border-amber-500 transition-all bg-slate-950 group" id="image-drop-zone">
                    <div class="flex flex-col items-center gap-3 pointer-events-none" id="image-placeholder">
                        <svg class="w-10 h-10 text-slate-700 group-hover:text-amber-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-slate-600 text-sm font-medium">Click to upload image</p>
                        <p class="mono text-[10px] text-slate-700 uppercase tracking-widest">PNG, JPG, WEBP</p>
                    </div>
                    <img id="image-preview" src="" alt="" class="hidden w-full h-full object-cover rounded-2xl">
                    <input type="file" name="image" accept="image/*" class="hidden" id="image-input">
                </label>
                <!-- URL fallback -->
                <div class="flex items-center gap-4">
                    <div class="h-px flex-1 bg-slate-800"></div>
                    <span class="mono text-[10px] text-slate-600 uppercase tracking-widest">or paste URL</span>
                    <div class="h-px flex-1 bg-slate-800"></div>
                </div>
                <input type="text" name="imageUrl" placeholder="https://res.cloudinary.com/..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Tags <span class="text-slate-700 normal-case tracking-normal font-normal">(semicolon-separated)</span></label>
                <input type="text" name="tags" required placeholder="C++;Robotics;SolidWorks"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Technical Details</label>
                <textarea name="details" required rows="6" placeholder="Methodology, calculations, outcomes, tools used..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700"></textarea>
            </div>

            <div class="pt-4">
                <button type="submit"
                    class="w-full bg-amber-500 text-black py-6 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-amber-500/10">
                    Deploy to Live Showcase
                </button>
            </div>
        </form>
    </div>
</section>

<script>
    const input = document.getElementById('image-input');
    const preview = document.getElementById('image-preview');
    const placeholder = document.getElementById('image-placeholder');
    input.addEventListener('change', () => {
        const file = input.files[0];
        if (!file) return;
        preview.src = URL.createObjectURL(file);
        preview.classList.remove('hidden');
        placeholder.classList.add('hidden');
    });
</script>

<%- include('../layout-end') %>
