<%- include('../layout-start') %>

<section class="py-24 px-6 min-h-screen bg-slate-950">
    <div class="max-w-2xl mx-auto">
        <div class="mb-16">
            <a href="/admin" class="mono text-[10px] font-bold text-emerald-400 uppercase tracking-[0.3em] hover:text-white transition-all mb-8 inline-block">← Return to Command Center</a>
            <h1 class="text-6xl font-extrabold text-white tracking-tighter">Add Award<span class="text-emerald-400">.</span></h1>
            <p class="text-slate-500 font-medium mt-4">Document a new distinction or honour.</p>
        </div>

        <form action="/admin/awards" method="POST" enctype="multipart/form-data"
            class="space-y-8 bg-slate-900 border border-slate-800 p-10 rounded-3xl shadow-2xl">

            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Award Title</label>
                <input type="text" name="title" required placeholder="e.g. 1st Place — National Robotics Competition"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-cyan-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Organization</label>
                    <input type="text" name="organization" required placeholder="e.g. Ministry of Innovation"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all placeholder:text-slate-700">
                </div>
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Year</label>
                    <input type="text" name="year" required placeholder="e.g. 2024"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all placeholder:text-slate-700">
                </div>
            </div>

            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Description</label>
                <textarea name="description" rows="4" placeholder="Brief description of the achievement..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all placeholder:text-slate-700"></textarea>
            </div>

            <!-- Award image upload -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">
                    Award Image <span class="text-slate-700 normal-case tracking-normal font-normal">— photo shown in the honours section</span>
                </label>
                <label class="flex flex-col items-center justify-center w-full h-44 border-2 border-dashed border-slate-700 rounded-2xl cursor-pointer hover:border-cyan-500 transition-all bg-slate-950 group">
                    <div id="img-placeholder" class="flex flex-col items-center gap-2 pointer-events-none">
                        <svg class="w-10 h-10 text-slate-700 group-hover:text-emerald-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-slate-600 text-sm font-medium">Click to upload image</p>
                        <p class="mono text-[10px] text-slate-700 uppercase tracking-widest">PNG, JPG, WEBP</p>
                    </div>
                    <img id="img-preview" src="" alt="" class="hidden w-full h-full object-cover rounded-2xl">
                    <input type="file" name="image" accept="image/*" class="hidden" id="img-input">
                </label>
                <div class="flex items-center gap-4">
                    <div class="h-px flex-1 bg-slate-800"></div>
                    <span class="mono text-[10px] text-slate-600 uppercase tracking-widest">or paste URL</span>
                    <div class="h-px flex-1 bg-slate-800"></div>
                </div>
                <input type="text" name="imageUrl" placeholder="https://res.cloudinary.com/..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="pt-4">
                <button type="submit"
                    class="w-full bg-gradient-to-r from-emerald-500 to-cyan-500 text-white hover:from-emerald-400 hover:to-cyan-400 border border-emerald-400/50 py-5 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-emerald-500/10">
                    Save Award
                </button>
            </div>
        </form>
    </div>
</section>

<script>
    const input = document.getElementById('img-input');
    const preview = document.getElementById('img-preview');
    const placeholder = document.getElementById('img-placeholder');
    input.addEventListener('change', () => {
        const file = input.files[0];
        if (!file) return;
        preview.src = URL.createObjectURL(file);
        preview.classList.remove('hidden');
        placeholder.classList.add('hidden');
    });
</script>

<%- include('../layout-end') %>
