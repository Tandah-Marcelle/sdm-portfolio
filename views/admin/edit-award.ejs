<%- include('../layout-start') %>
<section class="py-24 px-6 min-h-screen bg-slate-950">
    <div class="max-w-2xl mx-auto">
        <div class="mb-16">
            <a href="/admin" class="mono text-[10px] font-bold text-emerald-400 uppercase tracking-[0.3em] hover:text-white transition-all mb-8 inline-block">← Return to Command Center</a>
            <h1 class="text-6xl font-extrabold text-white tracking-tighter">Edit Award<span class="text-emerald-400">.</span></h1>
            <p class="text-slate-500 font-medium mt-4">Update <span class="text-white"><%= award.title %></span></p>
        </div>
        <form action="/admin/awards/<%= award.id %>/edit" method="POST" enctype="multipart/form-data"
            class="space-y-8 bg-slate-900 border border-slate-800 p-10 rounded-3xl shadow-2xl">

            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Award Title</label>
                <input type="text" name="title" required value="<%= award.title %>"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-cyan-500 outline-none transition-all">
            </div>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Organization</label>
                    <input type="text" name="organization" required value="<%= award.organization %>"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all">
                </div>
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Year</label>
                    <input type="text" name="year" required value="<%= award.year %>"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all">
                </div>
            </div>
            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Description</label>
                <textarea name="description" rows="4" class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-cyan-500 outline-none transition-all"><%= award.description %></textarea>
            </div>

            <!-- Image -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Award Image</label>
                <% if (award.image && award.image !== '') { %>
                <div class="relative rounded-2xl overflow-hidden border border-slate-800 h-40">
                    <img src="<%= award.image %>" id="img-preview" class="w-full h-full object-cover opacity-70">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="mono text-[10px] text-slate-400 bg-slate-950/80 px-3 py-1.5 rounded-full" id="img-label">Current Image</span>
                    </div>
                </div>
                <% } else { %>
                <img id="img-preview" src="" class="hidden w-full rounded-2xl border border-slate-800 h-40 object-cover">
                <% } %>
                <label class="flex items-center gap-4 border border-dashed border-slate-700 rounded-2xl p-5 cursor-pointer hover:border-cyan-500 transition-all bg-slate-950 group">
                    <svg class="w-8 h-8 text-slate-700 group-hover:text-emerald-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <p class="text-slate-400 text-sm font-medium group-hover:text-white transition-colors">Click to replace image</p>
                    <input type="file" name="image" accept="image/*" class="hidden" id="img-input">
                </label>
                <input type="hidden" name="imageUrl" value="<%= award.image %>">
            </div>

            <div class="flex gap-4 pt-4">
                <button type="submit" class="flex-1 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white hover:from-emerald-400 hover:to-cyan-400 border border-emerald-400/50 py-5 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-emerald-500/10">Save Changes</button>
                <a href="/admin" class="px-8 py-5 border border-slate-700 text-slate-400 rounded-full font-extrabold text-xs uppercase tracking-widest hover:border-slate-500 hover:text-white transition-all text-center">Cancel</a>
            </div>
        </form>
    </div>
</section>
<script>
    const input = document.getElementById('img-input');
    const preview = document.getElementById('img-preview');
    const label = document.getElementById('img-label');
    input.addEventListener('change', () => {
        const file = input.files[0]; if (!file) return;
        preview.src = URL.createObjectURL(file);
        preview.classList.remove('hidden'); preview.style.opacity = '1';
        if (label) label.textContent = 'New Image Selected';
    });
</script>
<%- include('../layout-end') %>
