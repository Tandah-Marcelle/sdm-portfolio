<%- include('../layout-start') %>

<section class="py-24 px-6 min-h-screen bg-slate-950">
    <div class="max-w-2xl mx-auto">
        <div class="mb-16">
            <a href="/admin" class="mono text-[10px] font-bold text-amber-500 uppercase tracking-[0.3em] hover:text-white transition-all mb-8 inline-block">← Return to Command Center</a>
            <h1 class="text-6xl font-extrabold text-white tracking-tighter">Add Certification<span class="text-amber-500">.</span></h1>
            <p class="text-slate-500 font-medium mt-4">Document a new professional credential.</p>
        </div>

        <form action="/admin/certifications" method="POST" enctype="multipart/form-data"
            class="space-y-8 bg-slate-900 border border-slate-800 p-10 rounded-3xl shadow-2xl">

            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Certification Name</label>
                <input type="text" name="name" required placeholder="e.g. Certified SolidWorks Professional (CSWP)"
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 font-bold text-white focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Issuing Organization</label>
                    <input type="text" name="issuer" required placeholder="e.g. Dassault Systèmes"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
                </div>
                <div class="grid gap-3">
                    <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Year Issued</label>
                    <input type="text" name="year" required placeholder="e.g. 2025"
                        class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
                </div>
            </div>

            <div class="grid gap-3">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">Description</label>
                <textarea name="description" rows="4" placeholder="What this certification covers, skills validated, exam details..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700"></textarea>
            </div>

            <!-- Badge upload -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">
                    Badge / Logo <span class="text-slate-700 normal-case tracking-normal font-normal">— small icon shown in carousel</span>
                </label>
                <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-slate-700 rounded-2xl cursor-pointer hover:border-amber-500 transition-all bg-slate-950 group">
                    <div id="badge-placeholder" class="flex flex-col items-center gap-2 pointer-events-none">
                        <svg class="w-8 h-8 text-slate-700 group-hover:text-amber-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                        </svg>
                        <p class="text-slate-600 text-sm font-medium">Upload badge image</p>
                    </div>
                    <img id="badge-preview" src="" alt="" class="hidden h-16 w-16 object-contain">
                    <input type="file" name="badge" accept="image/*" class="hidden" id="badge-input">
                </label>
                <div class="flex items-center gap-4">
                    <div class="h-px flex-1 bg-slate-800"></div>
                    <span class="mono text-[10px] text-slate-600 uppercase tracking-widest">or paste URL</span>
                    <div class="h-px flex-1 bg-slate-800"></div>
                </div>
                <input type="text" name="badgeUrl" placeholder="https://res.cloudinary.com/..."
                    class="w-full bg-slate-950 border border-slate-800 rounded-2xl p-5 text-slate-300 focus:border-amber-500 outline-none transition-all placeholder:text-slate-700">
            </div>

            <!-- Full certificate image upload -->
            <div class="grid gap-4">
                <label class="mono text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500">
                    Certificate Image <span class="text-slate-700 normal-case tracking-normal font-normal">— full photo shown on detail page</span>
                </label>
                <label class="flex flex-col items-center justify-center w-full h-40 border-2 border-dashed border-slate-700 rounded-2xl cursor-pointer hover:border-amber-500 transition-all bg-slate-950 group">
                    <div id="cert-img-placeholder" class="flex flex-col items-center gap-2 pointer-events-none">
                        <svg class="w-10 h-10 text-slate-700 group-hover:text-amber-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-slate-600 text-sm font-medium">Upload certificate photo</p>
                        <p class="mono text-[10px] text-slate-700 uppercase tracking-widest">PNG, JPG, WEBP</p>
                    </div>
                    <img id="cert-img-preview" src="" alt="" class="hidden w-full h-full object-cover rounded-2xl">
                    <input type="file" name="certImage" accept="image/*" class="hidden" id="cert-img-input">
                </label>
            </div>

            <div class="pt-4">
                <button type="submit"
                    class="w-full bg-amber-500 text-black py-5 rounded-full font-extrabold tracking-widest uppercase hover:bg-white hover:scale-[1.02] transition-all shadow-xl shadow-amber-500/10">
                    Save Certification
                </button>
            </div>
        </form>
    </div>
</section>

<script>
    function setupPreview(inputId, previewId, placeholderId) {
        const input = document.getElementById(inputId);
        const preview = document.getElementById(previewId);
        const placeholder = document.getElementById(placeholderId);
        if (!input) return;
        input.addEventListener('change', () => {
            const file = input.files[0];
            if (!file) return;
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
        });
    }
    setupPreview('badge-input', 'badge-preview', 'badge-placeholder');
    setupPreview('cert-img-input', 'cert-img-preview', 'cert-img-placeholder');
</script>

<%- include('../layout-end') %>
