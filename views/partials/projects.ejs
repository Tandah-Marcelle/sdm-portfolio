<section id="projects" class="py-32 relative overflow-hidden">

    <!-- bg2.jpg full bleed background -->
    <div class="absolute inset-0 z-0">
        <img src="/images/bg2.jpg" alt="" class="w-full h-full object-cover">
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, #020617 0%, rgba(2,6,23,0.82) 40%, rgba(2,6,23,0.88) 100%);"></div>
    </div>

    <div class="relative z-10 px-6">
        <div class="reveal flex justify-between items-end mb-20 max-w-7xl mx-auto">
            <div>
                <p class="mono text-amber-500 font-bold tracking-[0.3em] uppercase text-sm mb-4">Engineering Showcase</p>
                <h2 class="text-6xl font-extrabold text-white tracking-tighter">Case Studies.</h2>
                <p class="text-slate-400 font-medium mt-3 text-lg">Technical deep-dives and industrial implementations.</p>
            </div>
            <p class="mono text-sm text-slate-600 font-bold uppercase tracking-widest hidden md:block">
                <%= projects.length %> Projects Documented
            </p>
        </div>
    </div>

    <!-- Cards grid with padding and gaps -->
    <div class="relative z-10 px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <% projects.forEach((project, i) => { %>
        <div class="project-card group relative overflow-hidden cursor-pointer rounded-2xl border border-slate-800/60 hover:border-amber-500/40 transition-all duration-500"
             data-id="<%= project.id %>"
             style="min-height: 520px;">

            <!-- Background image -->
            <img src="<%= project.image %>" alt="<%= project.title %>"
                class="absolute inset-0 w-full h-full object-cover opacity-65 group-hover:opacity-90 group-hover:scale-105 transition-all duration-700">

            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-transparent"></div>

            <!-- REF badge -->
            <div class="absolute top-6 left-6 z-10">
                <span class="mono text-xs font-bold text-amber-500/60 bg-slate-950/70 border border-slate-800 px-3 py-1.5 rounded-full">
                    REF_<%= String(project.id).padStart(2, '0') %>
                </span>
            </div>

            <!-- Hover "View" indicator -->
            <div class="absolute top-6 right-6 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span class="mono text-xs font-bold text-white bg-amber-500 px-4 py-2 rounded-full">View →</span>
            </div>

            <!-- Content pinned to bottom -->
            <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
                <div class="flex flex-wrap gap-2 mb-4">
                    <% project.tags.split(';').forEach(tag => { %>
                    <span class="mono text-xs font-bold uppercase tracking-widest text-amber-500 bg-amber-500/10 px-3 py-1 rounded-md border border-amber-500/20">
                        <%= tag.trim() %>
                    </span>
                    <% }) %>
                </div>
                <h3 class="text-3xl font-extrabold text-white mb-3 tracking-tight"><%= project.title %></h3>
                <p class="text-slate-400 text-base leading-relaxed line-clamp-2"><%= project.description %></p>
                <div class="mt-6 flex items-center gap-3 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                    <span class="text-amber-500 text-sm font-bold uppercase tracking-widest">Open Case Study</span>
                    <span class="h-px w-8 bg-amber-500"></span>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    </div>

</section>

<!-- ═══════════════════ PROJECT MODAL ═══════════════════ -->
<div id="project-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 md:p-8">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-slate-950/95 backdrop-blur-sm"></div>

    <!-- Modal panel -->
    <div class="relative z-10 w-full max-w-5xl max-h-[90vh] overflow-y-auto bg-slate-900 border border-slate-800 rounded-3xl shadow-2xl">

        <!-- Close button -->
        <button id="modal-close"
            class="absolute top-6 right-6 z-20 w-10 h-10 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-400 hover:text-white hover:bg-amber-500 hover:border-amber-500 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <!-- Hero image -->
        <div class="aspect-[21/9] overflow-hidden rounded-t-3xl relative">
            <img id="modal-image" src="" alt="" class="w-full h-full object-cover opacity-70">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent"></div>
            <div class="absolute bottom-8 left-10">
                <div id="modal-tags" class="flex flex-wrap gap-2 mb-4"></div>
                <h2 id="modal-title" class="text-5xl font-extrabold text-white tracking-tighter"></h2>
            </div>
            <div class="absolute top-6 left-6">
                <span id="modal-ref" class="mono text-xs font-bold text-amber-500 bg-slate-950/80 border border-amber-500/30 px-3 py-1.5 rounded-full"></span>
            </div>
        </div>

        <!-- Body -->
        <div class="p-10 grid md:grid-cols-3 gap-10">

            <!-- Main content -->
            <div class="md:col-span-2 space-y-8">
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-amber-500 mb-3">Project Overview</p>
                    <p id="modal-description" class="text-slate-300 text-lg leading-relaxed"></p>
                </div>
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-slate-500 mb-3">Technical Details</p>
                    <p id="modal-details" class="text-slate-400 text-base leading-relaxed"></p>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <div class="bg-slate-950 border border-slate-800 rounded-2xl p-6">
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-slate-600 mb-4">Project Info</p>
                    <div class="space-y-4">
                        <div>
                            <p class="text-xs text-slate-600 uppercase tracking-widest font-bold mb-1">Reference</p>
                            <p id="modal-ref-sidebar" class="mono text-amber-500 font-bold"></p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-600 uppercase tracking-widest font-bold mb-2">Technologies</p>
                            <div id="modal-tags-sidebar" class="flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>

                <div class="bg-amber-500/5 border border-amber-500/20 rounded-2xl p-6">
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-amber-500/60 mb-3">Interested?</p>
                    <p class="text-slate-400 text-sm leading-relaxed mb-4">Want to discuss this project or a similar one?</p>
                    <a href="#contact" id="modal-contact-link"
                        class="block text-center bg-amber-500 text-black px-6 py-3 rounded-full font-extrabold text-xs uppercase tracking-widest hover:bg-white transition-all">
                        Get In Touch
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Project data island -->
<script>
    const projectsData = <%- JSON.stringify(projects) %>;

    // Open modal
    document.querySelectorAll('.project-card').forEach(card => {
        card.addEventListener('click', () => {
            const id = parseInt(card.dataset.id);
            const p = projectsData.find(x => x.id === id);
            if (!p) return;

            const ref = 'REF_' + String(p.id).padStart(2, '0');
            document.getElementById('modal-image').src = p.image;
            document.getElementById('modal-title').textContent = p.title;
            document.getElementById('modal-description').textContent = p.description;
            document.getElementById('modal-details').textContent = p.details || 'Full technical documentation coming soon.';
            document.getElementById('modal-ref').textContent = ref;
            document.getElementById('modal-ref-sidebar').textContent = ref;

            // Tags in hero
            const tagsHero = document.getElementById('modal-tags');
            tagsHero.innerHTML = p.tags.split(';').map(t =>
                `<span class="mono text-xs font-bold uppercase tracking-widest text-amber-500 bg-amber-500/10 px-3 py-1 rounded-md border border-amber-500/20">${t.trim()}</span>`
            ).join('');

            // Tags in sidebar
            const tagsSidebar = document.getElementById('modal-tags-sidebar');
            tagsSidebar.innerHTML = p.tags.split(';').map(t =>
                `<span class="mono text-xs font-bold uppercase tracking-widest text-slate-400 bg-slate-900 border border-slate-800 px-3 py-1 rounded-md">${t.trim()}</span>`
            ).join('');

            const modal = document.getElementById('project-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });
    });

    // Close modal
    function closeModal() {
        const modal = document.getElementById('project-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }

    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-backdrop').addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // Close modal when contact link is clicked
    document.getElementById('modal-contact-link').addEventListener('click', closeModal);
</script>
