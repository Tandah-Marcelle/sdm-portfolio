<section id="projects" class="py-32 relative overflow-hidden">

    <div class="absolute inset-0 z-0">
        <img src="/images/bg2.jpg" alt="" class="w-full h-full object-cover">
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, var(--bg) 0%, rgba(0,0,0,0.82) 40%, rgba(0,0,0,0.88) 100%);"></div>
    </div>

    <div class="relative z-10 px-6">
        <div class="reveal flex justify-between items-end mb-20 max-w-7xl mx-auto">
            <div>
                <p class="mono font-bold tracking-[0.3em] uppercase text-sm mb-4 accent-green">Engineering Showcase</p>
                <h2 class="text-6xl font-extrabold tracking-tighter" style="color:#fff">Case Studies.</h2>
                <p class="font-medium mt-3 text-lg" style="color:rgba(255,255,255,0.6)">Technical deep-dives and industrial implementations.</p>
            </div>
            <p class="mono text-sm font-bold uppercase tracking-widest hidden md:block" style="color:rgba(255,255,255,0.3)">
                <%= projects.length %> Projects Documented
            </p>
        </div>
    </div>

    <div class="relative z-10 px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <% projects.forEach(project => { %>
            <div class="project-card group relative overflow-hidden cursor-pointer rounded-2xl transition-all duration-500"
                 data-id="<%= project.id %>"
                 style="min-height: 520px; border:1px solid rgba(255,255,255,0.1)">

                <img src="<%= project.image %>" alt="<%= project.title %>"
                    class="absolute inset-0 w-full h-full object-cover group-hover:group-hover:scale-105 transition-all duration-700">
                <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.3) 50%, transparent 100%)"></div>

                <div class="absolute top-6 left-6 z-10">
                    <span class="mono text-xs font-bold px-3 py-1.5 rounded-full accent-green"
                        style="background:rgba(0,0,0,0.7); border:1px solid rgba(2,138,15,0.4)">
                        REF_<%= String(project.id).padStart(2, '0') %>
                    </span>
                </div>

                <div class="absolute top-6 right-6 z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <span class="mono text-xs font-bold text-white px-4 py-2 rounded-full" style="background:var(--green)">View →</span>
                </div>

                <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
                    <div class="flex flex-wrap gap-2 mb-4">
                        <% project.tags.split(';').forEach(tag => { %>
                        <span class="mono text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-md accent-green"
                            style="background:rgba(2,138,15,0.15); border:1px solid rgba(2,138,15,0.3)">
                            <%= tag.trim() %>
                        </span>
                        <% }) %>
                    </div>
                    <h3 class="text-3xl font-extrabold mb-3 tracking-tight" style="color:#fff"><%= project.title %></h3>
                    <p class="text-base leading-relaxed line-clamp-2" style="color:rgba(255,255,255,0.6)"><%= project.description %></p>
                    <div class="mt-6 flex items-center gap-3 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
                        <span class="text-sm font-bold uppercase tracking-widest accent-green">Open Case Study</span>
                        <span class="h-px w-8" style="background:var(--green)"></span>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

</section>

<!-- PROJECT MODAL -->
<div id="project-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 md:p-8">
    <div id="modal-backdrop" class="absolute inset-0 backdrop-blur-sm" style="background:rgba(0,0,0,0.95)"></div>

    <div class="relative z-10 w-full max-w-5xl max-h-[90vh] overflow-y-auto rounded-3xl shadow-2xl"
        style="background:var(--bg-card); border:1px solid var(--border)">

        <button id="modal-close"
            class="absolute top-6 right-6 z-20 w-10 h-10 rounded-full flex items-center justify-center transition-all"
            style="background:var(--bg-card-2); border:1px solid var(--border); color:var(--text-3)"
            onmouseover="this.style.background='var(--green)'; this.style.color='#fff'; this.style.borderColor='var(--green)'"
            onmouseout="this.style.background='var(--bg-card-2)'; this.style.color='var(--text-3)'; this.style.borderColor='var(--border)'">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>

        <div class="aspect-[21/9] overflow-hidden rounded-t-3xl relative">
            <img id="modal-image" src="" alt="" class="w-full h-full object-cover opacity-70">
            <div class="absolute inset-0" style="background: linear-gradient(to top, var(--bg-card) 0%, transparent 60%)"></div>
            <div class="absolute bottom-8 left-10">
                <div id="modal-tags" class="flex flex-wrap gap-2 mb-4"></div>
                <h2 id="modal-title" class="text-5xl font-extrabold tracking-tighter" style="color:#fff"></h2>
            </div>
            <div class="absolute top-6 left-6">
                <span id="modal-ref" class="mono text-xs font-bold px-3 py-1.5 rounded-full accent-green"
                    style="background:rgba(0,0,0,0.8); border:1px solid rgba(2,138,15,0.4)"></span>
            </div>
        </div>

        <div class="p-10 grid md:grid-cols-3 gap-10">
            <div class="md:col-span-2 space-y-8">
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] mb-3 accent-green">Project Overview</p>
                    <p id="modal-description" class="text-lg leading-relaxed" style="color:var(--text-2)"></p>
                </div>
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] mb-3 accent-blue">Technical Details</p>
                    <p id="modal-details" class="text-base leading-relaxed" style="color:var(--text-3)"></p>
                </div>
            </div>

            <div class="space-y-6">
                <div class="rounded-2xl p-6" style="background:var(--bg-card-2); border:1px solid var(--border)">
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] mb-4" style="color:var(--text-muted)">Project Info</p>
                    <div class="space-y-4">
                        <div>
                            <p class="text-xs uppercase tracking-widest font-bold mb-1" style="color:var(--text-muted)">Reference</p>
                            <p id="modal-ref-sidebar" class="mono font-bold accent-green"></p>
                        </div>
                        <div>
                            <p class="text-xs uppercase tracking-widest font-bold mb-2" style="color:var(--text-muted)">Technologies</p>
                            <div id="modal-tags-sidebar" class="flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl p-6" style="background:rgba(2,138,15,0.05); border:1px solid rgba(2,138,15,0.2)">
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] mb-3 accent-green" style="opacity:0.7">Interested?</p>
                    <p class="text-sm leading-relaxed mb-4" style="color:var(--text-3)">Want to discuss this project or a similar one?</p>
                    <a href="#contact" id="modal-contact-link"
                        class="block text-center px-6 py-3 rounded-full font-extrabold text-xs uppercase tracking-widest hover:opacity-90 transition-all"
                        style="background:var(--green); color:#fff">
                        Get In Touch
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const projectsData = <%- JSON.stringify(projects) %>;

    document.querySelectorAll('.project-card').forEach(card => {
        card.addEventListener('click', () => {
            const id = parseInt(card.dataset.id);
            const p = projectsData.find(x => x.id === id);
            if (!p) return;

            const ref = 'REF_' + String(p.id).padStart(2, '0');
            document.getElementById('modal-image').src = p.image;
            document.getElementById('modal-title').textContent = p.title;
            document.getElementById('modal-description').textContent = p.description;
            document.getElementById('modal-details').textContent = p.details || 'Full technical documentation coming soon.';
            document.getElementById('modal-ref').textContent = ref;
            document.getElementById('modal-ref-sidebar').textContent = ref;

            document.getElementById('modal-tags').innerHTML = p.tags.split(';').map(t =>
                `<span class="mono text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-md accent-green" style="background:rgba(2,138,15,0.15);border:1px solid rgba(2,138,15,0.3)">${t.trim()}</span>`
            ).join('');

            document.getElementById('modal-tags-sidebar').innerHTML = p.tags.split(';').map(t =>
                `<span class="mono text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-md" style="color:var(--text-2);background:var(--bg-card-2);border:1px solid var(--border)">${t.trim()}</span>`
            ).join('');

            const modal = document.getElementById('project-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });
    });

    function closeModal() {
        const modal = document.getElementById('project-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }

    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-backdrop').addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
    document.getElementById('modal-contact-link').addEventListener('click', closeModal);
</script>
