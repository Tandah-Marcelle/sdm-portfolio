<section id="awards" class="py-32 px-6" style="background-color:var(--bg)">
    <div class="max-w-7xl mx-auto">

        <div class="reveal text-center mb-24">
            <p class="mono font-bold tracking-[0.3em] uppercase text-sm mb-4 accent-green">Recognition</p>
            <h2 class="text-6xl font-extrabold tracking-tighter italic" style="color:var(--text)">Distinctions & Honours.</h2>
            <p class="mt-4 text-lg" style="color:var(--text-3)">National and international recognition for engineering excellence.</p>
        </div>

        <div class="space-y-10">
            <% awards.forEach((award, i) => {
                const isEven = i % 2 === 0;
                const accentColor = isEven ? 'var(--green)' : 'var(--blue)';
            %>
            <div class="reveal group rounded-3xl overflow-hidden transition-all duration-500"
                style="background:var(--bg-card); border:1px solid var(--border); min-height:320px">

                <% if (isEven) { %>
                <!-- ODD (0,2…): image LEFT 2/3 — content RIGHT 1/3 -->
                <div class="flex flex-col md:flex-row h-full">

                    <!-- Image — 2/3 -->
                    <div class="relative md:w-2/3 min-h-[280px] overflow-hidden">
                        <% if (award.image && award.image !== '') { %>
                        <img src="<%= award.image %>" alt="<%= award.title %>"
                            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700">
                        <% } else { %>
                        <div class="absolute inset-0 flex items-center justify-center" style="background:var(--bg-card-2)">
                            <div class="absolute inset-0 opacity-5"
                                style="background-image:radial-gradient(<%= accentColor %> 1px,transparent 1px);background-size:32px 32px"></div>
                            <span class="mono font-extrabold select-none" style="font-size:10rem;line-height:1;color:<%= accentColor %>;opacity:0.08">/0<%= i+1 %></span>
                        </div>
                        <% } %>
                        <!-- fade to right toward content -->
                        <div class="absolute inset-0" style="background:linear-gradient(to right, transparent 55%, var(--bg-card) 100%)"></div>
                        <!-- number badge -->
                        <div class="absolute top-7 left-7 z-10">
                            <span class="mono text-3xl font-extrabold" style="color:<%= accentColor %>;opacity:0.5">/0<%= i+1 %></span>
                        </div>
                    </div>

                    <!-- Styled divider -->
                    <div class="hidden md:flex flex-col items-center justify-center w-px relative" style="background:var(--border)">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center z-10 relative" style="background:var(--bg-card);border:2px solid <%= accentColor %>">
                            <div class="w-2.5 h-2.5 rounded-full" style="background:<%= accentColor %>"></div>
                        </div>
                        <div class="absolute top-0 bottom-0 w-px" style="background:linear-gradient(to bottom, transparent, <%= accentColor %>60, transparent)"></div>
                    </div>

                    <!-- Content — 1/3 -->
                    <div class="md:w-1/3 p-10 flex flex-col justify-center">
                        <span class="mono text-xs font-bold uppercase tracking-[0.3em] px-3 py-1.5 rounded-full mb-5 self-start"
                            style="color:<%= accentColor %>;border:1px solid <%= accentColor %>50;background:<%= accentColor %>15">
                            <%= award.year %>
                        </span>
                        <h3 class="text-2xl font-extrabold tracking-tight leading-snug mb-4" style="color:var(--text)">
                            <%= award.title %>
                        </h3>
                        <p class="mono text-sm font-bold uppercase tracking-widest mb-5" style="color:<%= accentColor %>">
                            <%= award.organization %>
                        </p>
                        <% if (award.description) { %>
                        <p class="text-base leading-relaxed" style="color:var(--text-2)"><%= award.description %></p>
                        <% } %>
                    </div>

                </div>

                <% } else { %>
                <!-- EVEN (1,3…): content LEFT 1/3 — image RIGHT 2/3 -->
                <div class="flex flex-col md:flex-row h-full">

                    <!-- Content — 1/3 -->
                    <div class="md:w-1/3 p-10 flex flex-col justify-center">
                        <span class="mono text-xs font-bold uppercase tracking-[0.3em] px-3 py-1.5 rounded-full mb-5 self-start"
                            style="color:<%= accentColor %>;border:1px solid <%= accentColor %>50;background:<%= accentColor %>15">
                            <%= award.year %>
                        </span>
                        <h3 class="text-2xl font-extrabold tracking-tight leading-snug mb-4" style="color:var(--text)">
                            <%= award.title %>
                        </h3>
                        <p class="mono text-sm font-bold uppercase tracking-widest mb-5" style="color:<%= accentColor %>">
                            <%= award.organization %>
                        </p>
                        <% if (award.description) { %>
                        <p class="text-base leading-relaxed" style="color:var(--text-2)"><%= award.description %></p>
                        <% } %>
                    </div>

                    <!-- Styled divider -->
                    <div class="hidden md:flex flex-col items-center justify-center w-px relative" style="background:var(--border)">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center z-10 relative" style="background:var(--bg-card);border:2px solid <%= accentColor %>">
                            <div class="w-2.5 h-2.5 rounded-full" style="background:<%= accentColor %>"></div>
                        </div>
                        <div class="absolute top-0 bottom-0 w-px" style="background:linear-gradient(to bottom, transparent, <%= accentColor %>60, transparent)"></div>
                    </div>

                    <!-- Image — 2/3 -->
                    <div class="relative md:w-2/3 min-h-[280px] overflow-hidden">
                        <% if (award.image && award.image !== '') { %>
                        <img src="<%= award.image %>" alt="<%= award.title %>"
                            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700">
                        <% } else { %>
                        <div class="absolute inset-0 flex items-center justify-center" style="background:var(--bg-card-2)">
                            <div class="absolute inset-0 opacity-5"
                                style="background-image:radial-gradient(<%= accentColor %> 1px,transparent 1px);background-size:32px 32px"></div>
                            <span class="mono font-extrabold select-none" style="font-size:10rem;line-height:1;color:<%= accentColor %>;opacity:0.08">/0<%= i+1 %></span>
                        </div>
                        <% } %>
                        <!-- fade to left toward content -->
                        <div class="absolute inset-0" style="background:linear-gradient(to left, transparent 55%, var(--bg-card) 100%)"></div>
                        <!-- number badge -->
                        <div class="absolute top-7 right-7 z-10">
                            <span class="mono text-3xl font-extrabold" style="color:<%= accentColor %>;opacity:0.5">/0<%= i+1 %></span>
                        </div>
                    </div>

                </div>
                <% } %>

            </div>
            <% }) %>
        </div>

    </div>
</section>
