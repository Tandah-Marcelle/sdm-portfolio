<section id="experience" class="py-32 px-6">
    <div class="max-w-7xl mx-auto">

        <div class="reveal mb-20">
            <p class="mono text-amber-500 font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Career Trajectory</p>
            <h2 class="text-5xl font-extrabold text-white tracking-tighter">Professional Experience.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <% [
                {
                    role: 'Lead Mechatronics Engineer',
                    org: 'Sparte Robotics — Yaoundé, Cameroon',
                    period: '2023 — Present',
                    type: 'Full-Time',
                    points: [
                        'Led design and fabrication of award-winning autonomous robotics systems',
                        'Developed embedded firmware for multi-sensor aquatic exploration robots',
                        'Managed cross-functional teams for national competition entries'
                    ]
                },
                {
                    role: 'Mechanical Design Engineer',
                    org: 'IUC Engineering Lab — Yaoundé',
                    period: '2022 — 2023',
                    type: 'Academic / Research',
                    points: [
                        'Designed and simulated the Charcoal Cocoa Dryer thermal system in SolidWorks',
                        'Developed the Plastic Extrusion Machine — graded Excellent',
                        'Conducted FEA analysis and material selection for industrial prototypes'
                    ]
                },
                {
                    role: 'Embedded Systems Developer',
                    org: 'Freelance / Independent Projects',
                    period: '2021 — Present',
                    type: 'Freelance',
                    points: [
                        'Built CNC laser engraver with GRBL-based motion control firmware',
                        'Developed dual-extrusion 3D printer with Wi-Fi remote management',
                        'Integrated computer vision pipelines for obstacle avoidance systems'
                    ]
                },
                {
                    role: 'Engineering Intern',
                    org: 'Industrial Manufacturing Facility',
                    period: '2020 — 2021',
                    type: 'Internship',
                    points: [
                        'Assisted in CNC machine operation and maintenance',
                        'Supported PLC programming for automated production lines',
                        'Performed quality control inspections and technical documentation'
                    ]
                }
            ].forEach(exp => { %>
            <div class="reveal card-glow bg-slate-900/40 border border-slate-800 rounded-3xl p-8 hover:border-amber-500/30 transition-all duration-500">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2"><%= exp.role %></h3>
                        <p class="text-base text-slate-400 font-medium"><%= exp.org %></p>
                    </div>
                    <div class="text-right shrink-0 ml-4">
                        <p class="mono text-sm text-amber-500 font-bold"><%= exp.period %></p>
                        <span class="mono text-xs font-bold uppercase tracking-widest text-slate-500 bg-slate-900 border border-slate-800 px-3 py-1 rounded-md mt-2 inline-block"><%= exp.type %></span>
                    </div>
                </div>
                <ul class="space-y-3">
                    <% exp.points.forEach(pt => { %>
                    <li class="flex items-start gap-3 text-base text-slate-400">
                        <span class="text-amber-500 mt-1 shrink-0">›</span>
                        <%= pt %>
                    </li>
                    <% }) %>
                </ul>
            </div>
            <% }) %>
        </div>

        <div class="reveal mt-16 bg-slate-900/20 border border-slate-900 rounded-3xl p-10">
            <p class="mono text-sm font-bold uppercase tracking-[0.3em] text-slate-400 mb-8">Education</p>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="flex gap-6">
                    <div class="w-14 h-14 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center shrink-0">
                        <span class="text-amber-500 font-extrabold text-base">IUC</span>
                    </div>
                    <div>
                        <h4 class="text-white font-bold text-lg mb-1">B.Eng. Electromechanical Engineering</h4>
                        <p class="text-slate-400 text-base">Institut Universitaire de la Côte (IUC)</p>
                        <p class="mono text-sm text-amber-500 mt-1">2019 — 2024</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="w-14 h-14 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center shrink-0">
                        <span class="text-amber-500 font-extrabold text-base">DS</span>
                    </div>
                    <div>
                        <h4 class="text-white font-bold text-lg mb-1">3DExperience Platform Certification</h4>
                        <p class="text-slate-400 text-base">Dassault Systèmes — Online</p>
                        <p class="mono text-sm text-amber-500 mt-1">2023 — 2025</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
