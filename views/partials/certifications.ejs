<section id="certifications" class="py-32 px-6 overflow-hidden relative" style="border-top:1px solid var(--border); border-bottom:1px solid var(--border)">

    <!-- green_certif.jpg full-bleed background -->
    <div class="absolute inset-0 z-0">
        <img src="/images/green_certif.png" alt="" class="w-full h-full object-cover">
        <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.72) 50%, rgba(0,0,0,0.88) 100%)"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">

        <div class="reveal text-center mb-3">
            <p class="mono font-bold tracking-[0.3em] uppercase text-sm mb-4 accent-green">Credentials</p>
            <h2 class="text-5xl font-extrabold tracking-tighter" style="color:#fff">Certifications.</h2>
            <p class="mt-3 text-xl max-w-2xl mx-auto leading-relaxed" style="color:rgba(255,255,255,0.65)">Each credential represents a validated mastery of engineering tools, design platforms, and technical disciplines — earned through rigorous examination and hands-on practice.</p>
        </div>

        <div class="relative flex items-center justify-center" style="height: 900px; perspective: 2000px;">
            <% certifications.forEach((cert, i) => { %>
            <a href="/certifications/<%= cert.id %>"
               class="cert-card absolute transition-all duration-500 cursor-pointer"
               data-index="<%= i %>"
               style="width: 640px;">
                <div class="rounded-3xl overflow-hidden shadow-2xl group transition-all duration-300"
                    style="background:rgba(0,0,0,0.75); border:1px solid rgba(255,255,255,0.1); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px)">
                    <div class="h-96 flex items-center justify-center relative overflow-hidden" style="background:rgba(0,0,0,0.5)">
                        <div class="absolute inset-0 opacity-5"
                            style="background-image: radial-gradient(var(--<%= i%2===0?'green':'blue' %>) 1px, transparent 1px); background-size: 24px 24px;"></div>
                        <% if (cert.image && cert.image !== '') { %>
                        <img src="<%= cert.image %>" alt="" class="absolute inset-0 w-full h-full object-cover group-hover:opacity-80 transition-opacity duration-500">
                        <% } %>
                        <% if (cert.badge && cert.badge !== '') { %>
                        <img src="<%= cert.badge %>" alt="<%= cert.name %>"
                            class="w-48 h-48 object-contain relative z-10 drop-shadow-2xl"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="hidden w-44 h-44 rounded-full items-center justify-center relative z-10"
                            style="background:rgba(2,138,15,0.1); border:2px solid rgba(2,138,15,0.3)">
                            <span class="font-extrabold text-7xl accent-green">✓</span>
                        </div>
                        <% } else { %>
                        <div class="w-44 h-44 rounded-full flex items-center justify-center relative z-10"
                            style="background:rgba(2,138,15,0.1); border:2px solid rgba(2,138,15,0.3)">
                            <span class="font-extrabold text-7xl accent-green">✓</span>
                        </div>
                        <% } %>
                        <div class="absolute inset-0" style="background: linear-gradient(to top, var(--bg-card) 0%, transparent 60%)"></div>
                        <div class="absolute bottom-3 right-3 z-10 opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="mono text-[10px] font-bold text-white px-3 py-1 rounded-full uppercase tracking-widest"
                                style="background:var(--green)">View →</span>
                        </div>
                    </div>
                    <div class="p-10">
                        <h4 class="font-extrabold text-3xl leading-snug mb-4" style="color:#fff"><%= cert.name %></h4>
                        <p class="text-xl font-medium mb-6" style="color:rgba(255,255,255,0.7)"><%= cert.issuer %></p>
                        <div class="flex items-center justify-between">
                            <span class="mono text-lg font-bold px-6 py-2.5 rounded-full accent-green"
                                style="background:rgba(2,138,15,0.1); border:1px solid rgba(2,138,15,0.3)">
                                <%= cert.year %>
                            </span>
                            <span class="mono text-base font-bold uppercase tracking-widest accent-blue">✓ Verified</span>
                        </div>
                    </div>
                </div>
            </a>
            <% }) %>
        </div>

        <div class="flex items-center justify-center gap-6 mt-12">
            <button id="cert-prev" class="w-16 h-16 rounded-full flex items-center justify-center transition-all"
                style="border:1px solid var(--border); color:var(--text-3)"
                onmouseover="this.style.borderColor='var(--green)'; this.style.color='var(--green)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-3)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            <div id="cert-dots" class="flex gap-3">
                <% certifications.forEach((_, i) => { %>
                <button class="cert-dot w-2 h-2 rounded-full transition-all" data-dot="<%= i %>"
                    style="background:var(--border-2)"></button>
                <% }) %>
            </div>
            <button id="cert-next" class="w-16 h-16 rounded-full flex items-center justify-center transition-all"
                style="border:1px solid var(--border); color:var(--text-3)"
                onmouseover="this.style.borderColor='var(--blue)'; this.style.color='var(--blue)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-3)'">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </button>
        </div>

    </div>
</section>

<script>
(function () {
    const cards = Array.from(document.querySelectorAll('.cert-card'));
    const dots  = Array.from(document.querySelectorAll('.cert-dot'));
    const total = cards.length;
    if (total === 0) return;
    let active = Math.floor(total / 2);

    function applyLayout() {
        const green = getComputedStyle(document.documentElement).getPropertyValue('--green').trim();
        cards.forEach((card, i) => {
            const offset = i - active, absOff = Math.abs(offset);
            card.style.transform     = `translateX(${offset*520}px) translateZ(${offset===0?0:absOff===1?-200:-380}px) rotateY(${offset===0?0:offset>0?-32:32}deg) scale(${offset===0?1:absOff===1?0.74:0.55})`;
            card.style.filter        = `brightness(${offset===0?1:absOff===1?0.55:0.35})`;
            card.style.zIndex        = 10 - absOff;
            card.style.opacity       = absOff > 2 ? 0 : 1;
            card.style.pointerEvents = absOff > 2 ? 'none' : 'auto';
        });
        dots.forEach((dot, i) => {
            const isActive = i === active;
            dot.style.background = isActive ? 'var(--green)' : 'var(--border-2)';
            dot.style.width      = isActive ? '24px' : '8px';
        });
    }

    function goTo(index) { active = Math.max(0, Math.min(total-1, index)); applyLayout(); }

    cards.forEach((card, i) => card.addEventListener('click', (e) => { if (i !== active) { e.preventDefault(); goTo(i); } }));
    document.getElementById('cert-prev').addEventListener('click', () => goTo(active-1));
    document.getElementById('cert-next').addEventListener('click', () => goTo(active+1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    document.addEventListener('keydown', e => { if(e.key==='ArrowLeft') goTo(active-1); if(e.key==='ArrowRight') goTo(active+1); });

    let tx = 0;
    document.querySelector('#certifications').addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, {passive:true});
    document.querySelector('#certifications').addEventListener('touchend', e => { const d = tx - e.changedTouches[0].clientX; if(Math.abs(d)>50) goTo(active+(d>0?1:-1)); });

    applyLayout();
})();
</script>
