<section id="certifications" class="py-32 px-6 bg-slate-950/60 border-y border-slate-900 overflow-hidden">
    <div class="max-w-7xl mx-auto">

        <div class="reveal text-center mb-20">
            <p class="mono text-amber-500 font-bold tracking-[0.3em] uppercase text-sm mb-4">Credentials</p>
            <h2 class="text-5xl font-extrabold text-white tracking-tighter">Certifications.</h2>
            <p class="text-slate-500 mt-3 text-base">Click any card to view full credential details.</p>
        </div>

        <!-- Carousel viewport -->
        <div class="relative flex items-center justify-center" style="height: 440px; perspective: 1200px;">

            <% certifications.forEach((cert, i) => { %>
            <a href="/certifications/<%= cert.id %>"
               class="cert-card absolute transition-all duration-500 cursor-pointer"
               data-index="<%= i %>"
               style="width: 320px;">

                <div class="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden shadow-2xl group hover:border-amber-500/40 transition-all duration-300">
                    <!-- Image / Badge area -->
                    <div class="h-52 bg-gradient-to-br from-slate-800 to-slate-950 flex items-center justify-center relative overflow-hidden">
                        <div class="absolute inset-0 opacity-10"
                            style="background-image: radial-gradient(#f59e0b 1px, transparent 1px); background-size: 24px 24px;"></div>

                        <!-- Full image if available -->
                        <% if (cert.image && cert.image !== '') { %>
                        <img src="<%= cert.image %>" alt="<%= cert.name %>"
                            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity duration-500">
                        <% } %>

                        <!-- Badge on top -->
                        <% if (cert.badge && cert.badge !== '') { %>
                        <img src="<%= cert.badge %>" alt="<%= cert.name %>"
                            class="w-24 h-24 object-contain relative z-10 drop-shadow-2xl"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <div class="hidden w-20 h-20 rounded-full bg-amber-500/10 border-2 border-amber-500/30 items-center justify-center relative z-10">
                            <span class="text-amber-500 font-extrabold text-4xl">✓</span>
                        </div>
                        <% } else { %>
                        <div class="w-20 h-20 rounded-full bg-amber-500/10 border-2 border-amber-500/30 flex items-center justify-center relative z-10">
                            <span class="text-amber-500 font-extrabold text-4xl">✓</span>
                        </div>
                        <% } %>

                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 to-transparent"></div>

                        <!-- View detail hint -->
                        <div class="absolute bottom-3 right-3 z-10 opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="mono text-[10px] font-bold text-white bg-amber-500 px-3 py-1 rounded-full uppercase tracking-widest">View →</span>
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="p-7">
                        <h4 class="text-white font-extrabold text-lg leading-snug mb-2"><%= cert.name %></h4>
                        <p class="text-slate-400 text-base font-medium mb-4"><%= cert.issuer %></p>
                        <div class="flex items-center justify-between">
                            <span class="mono text-sm font-bold text-amber-500 bg-amber-500/10 border border-amber-500/20 px-4 py-1.5 rounded-full">
                                <%= cert.year %>
                            </span>
                            <span class="mono text-xs text-emerald-500 font-bold uppercase tracking-widest">✓ Verified</span>
                        </div>
                    </div>
                </div>
            </a>
            <% }) %>

        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-center gap-6 mt-12">
            <button id="cert-prev"
                class="w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center text-slate-400 hover:border-amber-500 hover:text-amber-500 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            <div id="cert-dots" class="flex gap-3">
                <% certifications.forEach((_, i) => { %>
                <button class="cert-dot w-2 h-2 rounded-full bg-slate-700 hover:bg-amber-500 transition-all" data-dot="<%= i %>"></button>
                <% }) %>
            </div>
            <button id="cert-next"
                class="w-12 h-12 rounded-full border border-slate-700 flex items-center justify-center text-slate-400 hover:border-amber-500 hover:text-amber-500 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </button>
        </div>

    </div>
</section>

<script>
(function () {
    const cards = Array.from(document.querySelectorAll('.cert-card'));
    const dots  = Array.from(document.querySelectorAll('.cert-dot'));
    const total = cards.length;
    if (total === 0) return;

    let active = Math.floor(total / 2);

    function applyLayout() {
        cards.forEach((card, i) => {
            const offset = i - active;
            const absOff = Math.abs(offset);
            const scale  = offset === 0 ? 1 : (absOff === 1 ? 0.78 : 0.62);
            const tx     = offset * 260;
            const tz     = offset === 0 ? 0 : (absOff === 1 ? -120 : -220);
            const ry     = offset === 0 ? 0 : (offset > 0 ? -28 : 28);
            const bright = offset === 0 ? 1 : (absOff === 1 ? 0.55 : 0.35);
            const zIndex = 10 - absOff;
            const opacity = absOff > 2 ? 0 : 1;

            card.style.transform     = `translateX(${tx}px) translateZ(${tz}px) rotateY(${ry}deg) scale(${scale})`;
            card.style.filter        = `brightness(${bright})`;
            card.style.zIndex        = zIndex;
            card.style.opacity       = opacity;
            card.style.pointerEvents = absOff > 2 ? 'none' : 'auto';
        });

        dots.forEach((dot, i) => {
            dot.classList.toggle('bg-amber-500', i === active);
            dot.classList.toggle('w-6',          i === active);
            dot.classList.toggle('bg-slate-700', i !== active);
            dot.classList.toggle('w-2',          i !== active);
        });
    }

    function goTo(index) {
        active = Math.max(0, Math.min(total - 1, index));
        applyLayout();
    }

    // Clicking a non-active card focuses it; clicking the active card follows the link
    cards.forEach((card, i) => {
        card.addEventListener('click', (e) => {
            if (i !== active) {
                e.preventDefault();
                goTo(i);
            }
            // if active, let the <a> navigate naturally
        });
    });

    document.getElementById('cert-prev').addEventListener('click', () => goTo(active - 1));
    document.getElementById('cert-next').addEventListener('click', () => goTo(active + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    document.addEventListener('keydown', e => {
        if (e.key === 'ArrowLeft')  goTo(active - 1);
        if (e.key === 'ArrowRight') goTo(active + 1);
    });

    let touchStartX = 0;
    const viewport = document.querySelector('#certifications');
    viewport.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    viewport.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) goTo(active + (diff > 0 ? 1 : -1));
    });

    applyLayout();
})();
</script>
