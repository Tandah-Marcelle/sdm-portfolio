<style>
    /* ── Hero entrance animations ─────────────────────────── */
    @keyframes heroFadeUp {
        from { opacity: 0; transform: translateY(40px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes heroFadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @keyframes scanLine {
        0%   { top: -4px; opacity: 0.7; }
        100% { top: 100%; opacity: 0; }
    }
    @keyframes floatDot {
        0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0.4; }
        33%       { transform: translateY(-18px) translateX(8px); opacity: 0.8; }
        66%       { transform: translateY(10px) translateX(-6px); opacity: 0.5; }
    }
    @keyframes cursorBlink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
    }
    @keyframes statBarGrow {
        from { width: 0; }
        to   { width: 2rem; }
    }
    @keyframes glowPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(2,138,15,0); }
        50%       { box-shadow: 0 0 24px 6px rgba(2,138,15,0.18); }
    }

    .hero-tag    { animation: heroFadeUp 0.7s ease both; animation-delay: 0.1s; }
    .hero-name   { animation: heroFadeUp 0.8s ease both; animation-delay: 0.25s; }
    .hero-sub    { animation: heroFadeUp 0.8s ease both; animation-delay: 0.45s; }
    .hero-ctas   { animation: heroFadeUp 0.8s ease both; animation-delay: 0.6s; }
    .hero-stats  { animation: heroFadeUp 0.8s ease both; animation-delay: 0.8s; }

    .stat-bar-anim {
        width: 0;
        animation: statBarGrow 1s ease forwards;
    }
    .stat-bar-anim.green { background: var(--green); animation-delay: 1s; }
    .stat-bar-anim.blue  { background: var(--blue);  animation-delay: 1.1s; }

    .hero-cta-primary { animation: glowPulse 3s ease-in-out infinite; animation-delay: 1.5s; }

    .cursor-blink {
        display: inline-block;
        width: 4px;
        height: 0.85em;
        vertical-align: middle;
        margin-left: 4px;
        border-radius: 2px;
        animation: cursorBlink 1s step-end infinite;
    }

    .scan-line {
        position: absolute;
        left: 0; right: 0;
        height: 2px;
        background: linear-gradient(to right, transparent, var(--green), transparent);
        animation: scanLine 4s linear infinite;
        pointer-events: none;
        z-index: 5;
        opacity: 0;
    }

    .float-dot {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
</style>

<section class="min-h-[92vh] flex flex-col justify-center px-6 relative overflow-hidden" style="background-color:var(--bg)">

    <!-- Dot grid -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none"
        style="background-image: radial-gradient(var(--green) 1px, transparent 1px); background-size: 48px 48px;"></div>

    <!-- Scan line -->
    <div class="scan-line"></div>

    <!-- Floating particles -->
    <div id="hero-particles" class="absolute inset-0 pointer-events-none z-0"></div>

    <!-- bg1.png right side -->
    <div class="absolute top-0 right-0 h-full w-[45%] pointer-events-none">
        <img src="/images/bg1.png" alt="" class="w-full h-full object-cover object-left opacity-15"
            style="mask-image: linear-gradient(to right, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%);">
        <div class="absolute inset-0" style="background: linear-gradient(to right, var(--bg) 0%, transparent 35%);"></div>
    </div>

    <div class="max-w-7xl mx-auto w-full relative z-10">
        <div class="max-w-3xl">

            <!-- Tag -->
            <p class="hero-tag mono font-bold tracking-[0.35em] uppercase text-xs mb-6 accent-green accent-glow">
                Electromechanical Engineer · Industry 4.0 Specialist
            </p>

            <!-- Name with cursor -->
            <h1 class="hero-name text-7xl md:text-[110px] font-extrabold tracking-tighter leading-[0.85] mb-8" style="color:var(--text)">
                Manuel<br/>Dongmo<span class="accent-green">.</span><span class="cursor-blink" style="background:var(--green)"></span>
            </h1>

            <!-- Subtitle -->
            <p class="hero-sub text-xl md:text-2xl font-light max-w-2xl leading-relaxed" style="color:var(--text-2)">
                Designing intelligent machines at the intersection of
                <span class="font-semibold italic" style="color:var(--text)">Mechatronics</span>,
                <span class="font-semibold italic" style="color:var(--text)">Embedded Systems</span>, and
                <span class="font-semibold italic" style="color:var(--text)">Smart Manufacturing</span>.
            </p>

            <!-- CTAs -->
            <div class="hero-ctas mt-10 flex flex-wrap gap-5 items-center">
                <a href="#projects"
                    class="hero-cta-primary px-10 py-5 rounded-full font-extrabold text-xs uppercase tracking-widest hover:opacity-90 hover:scale-105 transition-all"
                    style="background-color:var(--green); color:#fff;">
                    View Case Studies
                </a>
                <a href="#contact"
                    class="px-10 py-5 rounded-full font-extrabold text-xs uppercase tracking-widest transition-all hover-blue"
                    style="border:1px solid var(--border-2); color:var(--text-2);">
                    Get In Touch
                </a>
            </div>
        </div>

        <!-- Stats strip -->
        <div class="hero-stats mt-20 grid grid-cols-3 max-w-2xl">
            <div class="pr-10" style="border-right:1px solid var(--border)">
                <div class="h-0.5 mb-4 stat-bar-anim green"></div>
                <p class="text-6xl font-extrabold tracking-tighter leading-none mb-2 stat-count" data-target="<%= profile.yearsExp %>" style="color:var(--text)"><%= profile.yearsExp %></p>
                <p class="mono text-xs font-bold uppercase tracking-[0.2em]" style="color:var(--text-3)">Years<br/>Experience</p>
            </div>
            <div class="px-10" style="border-right:1px solid var(--border)">
                <div class="h-0.5 mb-4 stat-bar-anim blue"></div>
                <p class="text-6xl font-extrabold tracking-tighter leading-none mb-2 stat-count" data-target="<%= projects.length %>" data-suffix="+" style="color:var(--text)">0+</p>
                <p class="mono text-xs font-bold uppercase tracking-[0.2em]" style="color:var(--text-3)">Engineering<br/>Projects</p>
            </div>
            <div class="pl-10">
                <div class="h-0.5 mb-4 stat-bar-anim green" style="animation-delay:1.2s"></div>
                <p class="text-6xl font-extrabold tracking-tighter leading-none mb-2 stat-count" data-target="<%= awards.length %>" style="color:var(--text)">0</p>
                <p class="mono text-xs font-bold uppercase tracking-[0.2em]" style="color:var(--text-3)">National<br/>Awards</p>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color:var(--text-muted)">
        <p class="mono text-[9px] uppercase tracking-[0.4em]">Scroll</p>
        <div class="w-px h-12" style="background: linear-gradient(to bottom, var(--text-muted), transparent)"></div>
    </div>

</section>

<script>
(function () {
    // ── Floating particles ─────────────────────────────────
    const container = document.getElementById('hero-particles');
    const green = '#028A0F', blue = '#0284c7';
    for (let i = 0; i < 18; i++) {
        const dot = document.createElement('div');
        dot.className = 'float-dot';
        const size = Math.random() * 5 + 3;
        const color = Math.random() > 0.5 ? green : blue;
        const delay = Math.random() * 6;
        const duration = 5 + Math.random() * 6;
        dot.style.cssText = `
            width:${size}px; height:${size}px;
            background:${color};
            left:${Math.random() * 55}%;
            top:${Math.random() * 100}%;
            opacity:0.35;
            animation: floatDot ${duration}s ease-in-out ${delay}s infinite;
        `;
        container.appendChild(dot);
    }

    // ── Count-up for numeric stats ─────────────────────────
    function countUp(el) {
        const raw    = el.dataset.target;
        const suffix = el.dataset.suffix || '';
        const num    = parseInt(raw);
        if (isNaN(num)) return; // e.g. "6+" — leave as-is
        let start = 0;
        const duration = 1400;
        const step = 16;
        const increment = num / (duration / step);
        const timer = setInterval(() => {
            start += increment;
            if (start >= num) { start = num; clearInterval(timer); }
            el.textContent = Math.floor(start) + suffix;
        }, step);
    }

    // Trigger count-up when stats enter viewport
    const statEls = document.querySelectorAll('.stat-count');
    const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                setTimeout(() => countUp(entry.target), 900);
                statsObserver.unobserve(entry.target);
            }
        });
    }, { threshold: 0.5 });
    statEls.forEach(el => statsObserver.observe(el));

    // ── Stop cursor blink after 4s (feels natural) ─────────
    setTimeout(() => {
        const cursor = document.querySelector('.cursor-blink');
        if (cursor) { cursor.style.animation = 'none'; cursor.style.opacity = '0'; }
    }, 4000);
})();
</script>
