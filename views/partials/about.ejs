<section id="about" class="py-32 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">

        <div class="reveal relative">
            <div class="aspect-square bg-slate-900 rounded-3xl overflow-hidden border border-slate-800 relative group">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent z-10"></div>
                <img src="<%= profile.photo || 'https://images.unsplash.com/photo-1581092580497-e0d23cb61462?q=80&w=1000&auto=format&fit=crop' %>"
                    class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
                    alt="<%= profile.name %>">
                <div class="absolute bottom-8 left-8 z-20">
                    <p class="mono text-amber-500 font-bold text-[10px] tracking-widest uppercase mb-1">Engineer · Innovator</p>
                    <p class="text-2xl font-bold text-white"><%= profile.name %></p>
                </div>
            </div>
            <div class="absolute -bottom-6 -right-6 bg-amber-500 text-black rounded-2xl p-5 shadow-2xl">
                <p class="font-extrabold text-lg leading-none">CSWP</p>
                <p class="text-[10px] font-bold uppercase tracking-wider mt-1">Certified</p>
            </div>
        </div>

        <div class="reveal">
            <p class="mono text-amber-500 font-bold tracking-[0.3em] uppercase text-[10px] mb-6">Expertise & Vision</p>
            <h2 class="text-5xl font-extrabold text-white tracking-tighter mb-8 leading-tight">
                Pioneering Industry 4.0<br/>through Mechatronic<br/><span class="italic">Integration.</span>
            </h2>
            <p class="text-slate-400 leading-relaxed mb-6"><%= profile.bio %></p>
            <p class="text-slate-500 leading-relaxed mb-10"><%= profile.bio2 %></p>
            <div class="grid gap-3">
                <div class="flex items-center space-x-4 border-l-2 border-amber-500 pl-6 py-2">
                    <span class="text-white font-bold"><%= profile.specialty1 %></span>
                </div>
                <div class="flex items-center space-x-4 border-l-2 border-slate-800 pl-6 py-2">
                    <span class="text-slate-300 font-semibold"><%= profile.specialty2 %></span>
                </div>
                <div class="flex items-center space-x-4 border-l-2 border-slate-800 pl-6 py-2">
                    <span class="text-slate-300 font-semibold"><%= profile.specialty3 %></span>
                </div>
                <div class="flex items-center space-x-4 border-l-2 border-slate-800 pl-6 py-2">
                    <span class="text-slate-300 font-semibold"><%= profile.specialty4 %></span>
                </div>
            </div>
        </div>

    </div>
</section>
