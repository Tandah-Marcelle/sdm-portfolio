<section id="about" class="py-32 px-6" style="background-color:var(--bg)">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center">

        <div class="reveal relative">
            <div class="aspect-square rounded-3xl overflow-hidden relative group" style="background:var(--bg-card); border:1px solid var(--border)">
                <div class="absolute inset-0 z-10" style="background: linear-gradient(to top, var(--bg) 0%, transparent 50%)"></div>
                <img src="<%= profile.photo || 'https://images.unsplash.com/photo-1581092580497-e0d23cb61462?q=80&w=1000&auto=format&fit=crop' %>"
                    class="w-full h-full object-cover "
                    alt="<%= profile.name %>">
                <div class="absolute bottom-8 left-8 z-20">
                    <p class="mono font-bold text-[10px] tracking-widest uppercase mb-1 accent-green">Engineer · Innovator</p>
                    <p class="text-2xl font-bold" style="color:var(--text)"><%= profile.name %></p>
                </div>
            </div>
            <div class="absolute -bottom-6 -right-6 rounded-2xl p-5 shadow-2xl" style="background:var(--green); color:#fff">
                <p class="font-extrabold text-lg leading-none">CSWP</p>
                <p class="text-[10px] font-bold uppercase tracking-wider mt-1">Certified</p>
            </div>
        </div>

        <div class="reveal">
            <p class="mono font-bold tracking-[0.3em] uppercase text-[10px] mb-6 accent-green">Expertise & Vision</p>
            <h2 class="text-5xl font-extrabold tracking-tighter mb-8 leading-tight" style="color:var(--text)">
                Pioneering Industry 4.0<br/>through Mechatronic<br/><span class="italic">Integration.</span>
            </h2>
            <p class="text-xl leading-relaxed mb-6" style="color:var(--text-2)"><%= profile.bio %></p>
            <p class="text-xl leading-relaxed mb-10" style="color:var(--text-3)"><%= profile.bio2 %></p>
            <div class="grid gap-3">
                <div class="flex items-center space-x-4 pl-6 py-2" style="border-left:2px solid var(--green)">
                    <span class="font-bold" style="color:var(--text)"><%= profile.specialty1 %></span>
                </div>
                <div class="flex items-center space-x-4 pl-6 py-2" style="border-left:2px solid var(--blue)">
                    <span class="font-semibold" style="color:var(--text-2)"><%= profile.specialty2 %></span>
                </div>
                <div class="flex items-center space-x-4 pl-6 py-2" style="border-left:2px solid var(--border-2)">
                    <span class="font-semibold" style="color:var(--text-2)"><%= profile.specialty3 %></span>
                </div>
                <div class="flex items-center space-x-4 pl-6 py-2" style="border-left:2px solid var(--border-2)">
                    <span class="font-semibold" style="color:var(--text-2)"><%= profile.specialty4 %></span>
                </div>
            </div>
        </div>

    </div>
</section>
