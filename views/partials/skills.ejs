<section id="skills" class="py-32 px-6 border-y border-slate-900 bg-slate-950/60 skills-section">
    <div class="max-w-7xl mx-auto">

        <div class="reveal text-center mb-20">
            <p class="mono text-amber-500 font-bold tracking-[0.3em] uppercase text-[10px] mb-4">Technical Arsenal</p>
            <h2 class="text-5xl font-extrabold text-white tracking-tighter">Core Competencies.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-16">

            <div class="reveal">
                <p class="mono text-sm font-bold uppercase tracking-[0.3em] text-slate-400 mb-8">Engineering & Design</p>
                <div class="space-y-7">
                    <% [
                        { name: 'SolidWorks / CAD Modeling', pct: 95 },
                        { name: 'Machine Design & Mechanisms', pct: 90 },
                        { name: 'Thermal & Fluid Systems', pct: 80 },
                        { name: 'CNC Machining & Fabrication', pct: 85 },
                        { name: '3D Printing & Rapid Prototyping', pct: 92 }
                    ].forEach(skill => { %>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-base font-semibold text-slate-200"><%= skill.name %></span>
                            <span class="mono text-sm text-amber-500 font-bold"><%= skill.pct %>%</span>
                        </div>
                        <div class="h-2 bg-slate-900 rounded-full overflow-hidden">
                            <div class="skill-bar-fill h-full bg-gradient-to-r from-amber-500 to-amber-400 rounded-full" data-width="<%= skill.pct %>%"></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <div class="reveal">
                <p class="mono text-sm font-bold uppercase tracking-[0.3em] text-slate-400 mb-8">Electronics & Software</p>
                <div class="space-y-7">
                    <% [
                        { name: 'Embedded C / C++ (Arduino, STM32)', pct: 88 },
                        { name: 'Python (Computer Vision, Automation)', pct: 82 },
                        { name: 'PLC Programming (Ladder / FBD)', pct: 78 },
                        { name: 'PCB Design & Electronics', pct: 75 },
                        { name: 'GRBL / G-Code / Motion Control', pct: 85 }
                    ].forEach(skill => { %>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-base font-semibold text-slate-200"><%= skill.name %></span>
                            <span class="mono text-sm text-amber-500 font-bold"><%= skill.pct %>%</span>
                        </div>
                        <div class="h-2 bg-slate-900 rounded-full overflow-hidden">
                            <div class="skill-bar-fill h-full bg-gradient-to-r from-amber-500 to-amber-400 rounded-full" data-width="<%= skill.pct %>%"></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

        </div>

        <div class="reveal mt-20 pt-16 border-t border-slate-900">
            <p class="mono text-sm font-bold uppercase tracking-[0.3em] text-slate-400 mb-8 text-center">Tools & Technologies</p>
            <div class="flex flex-wrap justify-center gap-3">
                <% ['SolidWorks', 'CATIA', '3DExperience', 'AutoCAD', 'Arduino', 'STM32', 'Raspberry Pi', 'Python', 'C++', 'GRBL', 'PLC', 'OpenCV', 'MATLAB', 'Fusion 360', 'KiCad', 'Marlin Firmware'].forEach(tech => { %>
                <span class="mono text-sm font-bold uppercase tracking-widest text-slate-300 bg-slate-900 border border-slate-800 px-5 py-3 rounded-lg hover:border-amber-500/50 hover:text-amber-500 transition-all cursor-default">
                    <%= tech %>
                </span>
                <% }) %>
            </div>
        </div>

    </div>
</section>
