<section id="skills" class="py-32 px-6 skills-section" style="background-color:var(--bg-2); border-top:1px solid var(--border); border-bottom:1px solid var(--border)">
    <div class="max-w-7xl mx-auto">

        <div class="reveal text-center mb-20">
            <p class="mono font-bold tracking-[0.3em] uppercase text-sm mb-4 accent-green">Technical Arsenal</p>
            <h2 class="text-5xl font-extrabold tracking-tighter" style="color:var(--text)">Core Competencies.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-16">

            <div class="reveal">
                <p class="mono text-sm font-bold uppercase tracking-[0.3em] mb-8 accent-green">Engineering & Design</p>
                <div class="space-y-7">
                    <% [
                        { name: 'SolidWorks / CAD Modeling', pct: 95 },
                        { name: 'Machine Design & Mechanisms', pct: 90 },
                        { name: 'Thermal & Fluid Systems', pct: 80 },
                        { name: 'CNC Machining & Fabrication', pct: 85 },
                        { name: '3D Printing & Rapid Prototyping', pct: 92 }
                    ].forEach(skill => { %>
                    <div>
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-xl font-semibold" style="color:var(--text-2)"><%= skill.name %></span>
                            <span class="mono text-lg font-bold accent-green"><%= skill.pct %>%</span>
                        </div>
                        <div class="h-3 rounded-full overflow-hidden" style="background:var(--bg-card-2)">
                            <div class="skill-bar-fill h-full rounded-full skill-bar-green" data-width="<%= skill.pct %>%"></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <div class="reveal">
                <p class="mono text-sm font-bold uppercase tracking-[0.3em] mb-8 accent-blue">Electronics & Software</p>
                <div class="space-y-7">
                    <% [
                        { name: 'Embedded C / C++ (Arduino, STM32)', pct: 88 },
                        { name: 'Python (Computer Vision, Automation)', pct: 82 },
                        { name: 'PLC Programming (Ladder / FBD)', pct: 78 },
                        { name: 'PCB Design & Electronics', pct: 75 },
                        { name: 'GRBL / G-Code / Motion Control', pct: 85 }
                    ].forEach(skill => { %>
                    <div>
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-xl font-semibold" style="color:var(--text-2)"><%= skill.name %></span>
                            <span class="mono text-lg font-bold accent-blue"><%= skill.pct %>%</span>
                        </div>
                        <div class="h-3 rounded-full overflow-hidden" style="background:var(--bg-card-2)">
                            <div class="skill-bar-fill h-full rounded-full skill-bar-blue" data-width="<%= skill.pct %>%"></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

        </div>

        <div class="reveal mt-20 pt-16" style="border-top:1px solid var(--border)">
            <p class="mono text-sm font-bold uppercase tracking-[0.3em] mb-8 text-center" style="color:var(--text-3)">Tools & Technologies</p>
            <div class="flex flex-wrap justify-center gap-3">
                <% ['SolidWorks','CATIA','3DExperience','AutoCAD','Arduino','STM32','Raspberry Pi','Python','C++','GRBL','PLC','OpenCV','MATLAB','Fusion 360','KiCad','Marlin Firmware'].forEach((tech, i) => { %>
                <span class="mono text-sm font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all cursor-default"
                    style="color:var(--text-2); background:var(--bg-card); border:1px solid var(--border)"
                    onmouseover="this.style.background='var(--green)'; this.style.color='#fff'; this.style.borderColor='var(--green)'"
                    onmouseout="this.style.background='var(--bg-card)'; this.style.color='var(--text-2)'; this.style.borderColor='var(--border)'">
                    <%= tech %>
                </span>
                <% }) %>
            </div>
        </div>

    </div>
</section>
