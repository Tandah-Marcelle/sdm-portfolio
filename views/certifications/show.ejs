<%- include('../layout-start') %>

<main class="min-h-screen">

    <!-- Hero -->
    <section class="relative py-40 px-6 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <% if (cert.image && cert.image !== '') { %>
            <img src="<%= cert.image %>" alt="" class="w-full h-full object-cover opacity-20">
            <% } %>
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, #020617 0%, rgba(2,6,23,0.85) 60%, #020617 100%);"></div>
            <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#f59e0b 1px, transparent 1px); background-size: 40px 40px;"></div>
        </div>

        <div class="relative z-10 max-w-5xl mx-auto">
            <a href="/#certifications" class="mono text-[11px] font-bold text-emerald-400 uppercase tracking-[0.3em] hover:text-white transition-colors inline-flex items-center gap-2 mb-12">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                Back to Portfolio
            </a>

            <div class="flex flex-col md:flex-row gap-12 items-center md:items-start">
                <!-- Badge -->
                <div class="shrink-0">
                    <div class="w-40 h-40 rounded-3xl bg-slate-900 border border-slate-800 flex items-center justify-center overflow-hidden shadow-2xl">
                        <% if (cert.badge && cert.badge !== '') { %>
                        <img src="<%= cert.badge %>" alt="<%= cert.name %>" class="w-28 h-28 object-contain drop-shadow-lg"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <span class="hidden text-emerald-400 font-extrabold text-5xl">✓</span>
                        <% } else { %>
                        <span class="text-emerald-400 font-extrabold text-5xl">✓</span>
                        <% } %>
                    </div>
                </div>

                <!-- Title block -->
                <div>
                    <p class="mono text-emerald-400 font-bold tracking-[0.3em] uppercase text-xs mb-4">Professional Credential</p>
                    <h1 class="text-5xl md:text-6xl font-extrabold text-white tracking-tighter leading-tight mb-6"><%= cert.name %></h1>
                    <div class="flex flex-wrap gap-4 items-center">
                        <span class="text-slate-300 text-lg font-semibold"><%= cert.issuer %></span>
                        <span class="w-1 h-1 rounded-full bg-slate-700"></span>
                        <span class="mono text-emerald-400 font-bold text-base bg-emerald-500/10 border border-emerald-500/20 px-4 py-1.5 rounded-full"><%= cert.year %></span>
                        <span class="mono text-xs font-bold text-emerald-500 bg-emerald-500/10 border border-emerald-500/20 px-4 py-1.5 rounded-full uppercase tracking-widest">✓ Verified</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="py-20 px-6">
        <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-12">

            <!-- Main description -->
            <div class="md:col-span-2 space-y-10">
                <% if (cert.description && cert.description !== '') { %>
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-emerald-400 mb-4">About This Credential</p>
                    <p class="text-slate-300 text-lg leading-relaxed"><%= cert.description %></p>
                </div>
                <% } %>

                <!-- Full image if provided -->
                <% if (cert.image && cert.image !== '') { %>
                <div>
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-slate-500 mb-4">Certificate</p>
                    <div class="rounded-3xl overflow-hidden border border-slate-800 shadow-2xl">
                        <img src="<%= cert.image %>" alt="<%= cert.name %>" class="w-full object-cover">
                    </div>
                </div>
                <% } %>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8">
                    <p class="mono text-xs font-bold uppercase tracking-[0.3em] text-slate-500 mb-6">Credential Details</p>
                    <div class="space-y-5">
                        <div>
                            <p class="mono text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-1">Certification</p>
                            <p class="text-white font-semibold text-sm leading-snug"><%= cert.name %></p>
                        </div>
                        <div class="border-t border-slate-800 pt-5">
                            <p class="mono text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-1">Issued By</p>
                            <p class="text-white font-semibold text-sm"><%= cert.issuer %></p>
                        </div>
                        <div class="border-t border-slate-800 pt-5">
                            <p class="mono text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-1">Year</p>
                            <p class="text-emerald-400 font-bold mono"><%= cert.year %></p>
                        </div>
                        <div class="border-t border-slate-800 pt-5">
                            <p class="mono text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-1">Status</p>
                            <p class="text-emerald-500 font-bold text-sm">Active & Verified</p>
                        </div>
                    </div>
                </div>

                <a href="/#contact"
                    class="block text-center bg-gradient-to-r from-emerald-500 to-cyan-500 text-white hover:from-emerald-400 hover:to-cyan-400 border border-emerald-400/50 px-6 py-4 rounded-full font-extrabold text-xs uppercase tracking-widest hover:bg-white hover:scale-105 transition-all shadow-lg shadow-emerald-500/20">
                    Contact Me
                </a>

                <a href="/#certifications"
                    class="block text-center border border-slate-700 text-slate-400 px-6 py-4 rounded-full font-extrabold text-xs uppercase tracking-widest hover:border-cyan-500 hover:text-emerald-400 transition-all">
                    ← All Certifications
                </a>
            </div>

        </div>
    </section>

</main>

<%- include('../layout-end') %>
