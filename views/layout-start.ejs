<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manuel Songfack Dongmo | Electromechanical Engineer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .mono { font-family: 'JetBrains Mono', monospace; }

        .glass {
            background: rgba(2, 6, 23, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .executive-gradient { background: linear-gradient(135deg, #020617 0%, #0f172a 100%); }
        .accent-glow { text-shadow: 0 0 30px rgba(245, 158, 11, 0.5); }
        .card-glow:hover { box-shadow: 0 0 40px rgba(245, 158, 11, 0.06); }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #f59e0b; }

        .reveal {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .skill-bar-fill {
            width: 0%;
            transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .timeline-line::before {
            content: '';
            position: absolute;
            left: 0;
            top: 8px;
            bottom: 0;
            width: 1px;
            background: linear-gradient(to bottom, #f59e0b, transparent);
        }

        @keyframes pulse-amber {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        .pulse-dot { animation: pulse-amber 2s infinite; }
    </style>
</head>

<body class="executive-gradient text-slate-200 min-h-screen selection:bg-amber-500/30 selection:text-amber-500">

    <nav class="fixed top-0 w-full z-50 glass border-b border-slate-800/60">
        <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
            <a href="/" class="text-xl font-extrabold tracking-tighter text-white">M.DONGMO<span class="text-amber-500">.</span></a>
            <div class="hidden md:flex items-center space-x-8 text-[11px] font-bold uppercase tracking-widest text-slate-400">
                <a href="#about" class="hover:text-amber-500 transition-colors">About</a>
                <a href="#skills" class="hover:text-amber-500 transition-colors">Skills</a>
                <a href="#experience" class="hover:text-amber-500 transition-colors">Experience</a>
                <a href="#projects" class="hover:text-amber-500 transition-colors">Projects</a>
                <a href="#awards" class="hover:text-amber-500 transition-colors">Awards</a>
                <a href="#certifications" class="hover:text-amber-500 transition-colors">Certifications</a>
                <a href="#contact" class="hover:text-amber-500 transition-colors">Contact</a>
                <a href="/admin" class="ml-4 border border-slate-700 px-5 py-2.5 rounded-full hover:border-amber-500 hover:text-amber-500 transition-all">Admin</a>
            </div>
            <!-- Mobile menu button -->
            <button id="mobile-menu-btn" class="md:hidden text-slate-400 hover:text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-950 px-6 py-6 space-y-4 text-[11px] font-bold uppercase tracking-widest text-slate-400">
            <a href="#about" class="block hover:text-amber-500 transition-colors">About</a>
            <a href="#skills" class="block hover:text-amber-500 transition-colors">Skills</a>
            <a href="#experience" class="block hover:text-amber-500 transition-colors">Experience</a>
            <a href="#projects" class="block hover:text-amber-500 transition-colors">Projects</a>
            <a href="#awards" class="block hover:text-amber-500 transition-colors">Awards</a>
            <a href="#certifications" class="block hover:text-amber-500 transition-colors">Certifications</a>
            <a href="#contact" class="block hover:text-amber-500 transition-colors">Contact</a>
            <a href="/admin" class="block hover:text-amber-500 transition-colors">Admin</a>
        </div>
    </nav>

    <div class="h-20"></div>

    <script>
        document.getElementById('mobile-menu-btn').addEventListener('click', () => {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });
    </script>
