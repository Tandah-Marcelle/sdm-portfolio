<!DOCTYPE html>
<html lang="en" class="scroll-smooth" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manuel Songfack Dongmo | Electromechanical Engineer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        /* ── THEME VARIABLES ─────────────────────────────────── */
        :root {
            /* Shared */
            --green:       #028A0F;
            --green-light: #03a813;
            --blue:        #0284c7;
            --blue-light:  #0ea5e9;

            /* Dark mode (default) */
            --bg:          #000000;
            --bg-2:        #0a0a0a;
            --bg-card:     #111111;
            --bg-card-2:   #181818;
            --border:      #222222;
            --border-2:    #2a2a2a;
            --text:        #f1f5f9;
            --text-2:      #94a3b8;
            --text-3:      #475569;
            --text-muted:  #334155;
            --nav-bg:      rgba(0,0,0,0.88);
            --scrollbar-track: #000;
            --scrollbar-thumb: #1a1a1a;
        }

        [data-theme="light"] {
            --bg:          #ffffff;
            --bg-2:        #f8fafc;
            --bg-card:     #f1f5f9;
            --bg-card-2:   #e2e8f0;
            --border:      #e2e8f0;
            --border-2:    #cbd5e1;
            --text:        #0f172a;
            --text-2:      #334155;
            --text-3:      #64748b;
            --text-muted:  #94a3b8;
            --nav-bg:      rgba(255,255,255,0.92);
            --scrollbar-track: #f1f5f9;
            --scrollbar-thumb: #cbd5e1;
        }

        /* ── BASE ────────────────────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .mono { font-family: 'JetBrains Mono', monospace; }

        /* ── SCROLLBAR ───────────────────────────────────────── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--scrollbar-track); }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--green); }

        /* ── NAV GLASS ───────────────────────────────────────── */
        .glass {
            background: var(--nav-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
        }

        /* ── THEME UTILITY CLASSES ───────────────────────────── */
        .bg-theme        { background-color: var(--bg); }
        .bg-theme-2      { background-color: var(--bg-2); }
        .bg-card         { background-color: var(--bg-card); }
        .bg-card-2       { background-color: var(--bg-card-2); }
        .border-theme    { border-color: var(--border); }
        .border-theme-2  { border-color: var(--border-2); }
        .text-theme      { color: var(--text); }
        .text-theme-2    { color: var(--text-2); }
        .text-theme-3    { color: var(--text-3); }
        .text-muted      { color: var(--text-muted); }

        /* Green accent */
        .accent-green    { color: var(--green); }
        .bg-green        { background-color: var(--green); }
        .border-green    { border-color: var(--green); }
        .hover-green:hover { color: var(--green); }

        /* Blue accent */
        .accent-blue     { color: var(--blue); }
        .bg-blue         { background-color: var(--blue); }
        .border-blue     { border-color: var(--blue); }
        .hover-blue:hover { color: var(--blue); }

        /* ── GLOW / EFFECTS ──────────────────────────────────── */
        .accent-glow { text-shadow: 0 0 30px rgba(2, 138, 15, 0.5); }
        .card-glow:hover { box-shadow: 0 0 40px rgba(2, 138, 15, 0.07); }
        .blue-glow:hover { box-shadow: 0 0 40px rgba(2, 132, 199, 0.07); }

        /* ── REVEAL ANIMATION ────────────────────────────────── */
        .reveal {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        /* ── SKILL BARS ──────────────────────────────────────── */
        .skill-bar-fill {
            width: 0%;
            transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .skill-bar-green { background-color: var(--green); }
        .skill-bar-blue  { background-color: var(--blue); }

        /* ── PULSE DOT ───────────────────────────────────────── */
        @keyframes pulse-green { 0%,100%{opacity:1} 50%{opacity:0.4} }
        .pulse-dot { animation: pulse-green 2s infinite; }

        /* ── SELECTION ───────────────────────────────────────── */
        ::selection { background: rgba(2,138,15,0.25); color: var(--green); }

        /* ── THEME TOGGLE BUTTON ─────────────────────────────── */
        .theme-toggle {
            width: 44px; height: 24px;
            background: var(--border-2);
            border-radius: 12px;
            position: relative;
            cursor: pointer;
            transition: background 0.3s;
            border: 1px solid var(--border);
            flex-shrink: 0;
        }
        .theme-toggle::after {
            content: '';
            position: absolute;
            top: 3px; left: 3px;
            width: 16px; height: 16px;
            border-radius: 50%;
            background: var(--green);
            transition: transform 0.3s;
        }
        [data-theme="light"] .theme-toggle::after { transform: translateX(20px); background: var(--blue); }

        /* ── INPUT / FORM THEMING ────────────────────────────── */
        .input-theme {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text);
        }
        .input-theme:focus { border-color: var(--green); outline: none; }
        .input-theme::placeholder { color: var(--text-muted); }

        /* ── CARD BORDER THEMING ─────────────────────────────── */
        .card-theme {
            background: var(--bg-card);
            border: 1px solid var(--border);
        }
        .card-theme:hover { border-color: var(--green); }
        .card-theme-blue:hover { border-color: var(--blue); }
    </style>
</head>

<body>
    <nav class="glass fixed top-0 w-full z-50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
            <a href="/" class="text-xl font-extrabold tracking-tighter text-theme">
                M.DONGMO<span class="accent-green">.</span>
            </a>

            <div class="hidden md:flex items-center space-x-8 text-[11px] font-bold uppercase tracking-widest text-theme-3">
                <a href="#about"          class="hover-green transition-colors">About</a>
                <a href="#skills"         class="hover-green transition-colors">Skills</a>
                <a href="#experience"     class="hover-green transition-colors">Experience</a>
                <a href="#projects"       class="hover-green transition-colors">Projects</a>
                <a href="#awards"         class="hover-green transition-colors">Awards</a>
                <a href="#certifications" class="hover-green transition-colors">Certifications</a>
                <a href="#contact"        class="hover-green transition-colors">Contact</a>
                <!-- Theme toggle -->
                <button class="theme-toggle" id="theme-toggle" title="Toggle light/dark mode" aria-label="Toggle theme"></button>
                <a href="/admin" class="border border-theme px-5 py-2.5 rounded-full hover:border-blue-500 hover-blue transition-all text-theme-3">Admin</a>
            </div>

            <div class="md:hidden flex items-center gap-4">
                <button class="theme-toggle" id="theme-toggle-mobile" title="Toggle theme" aria-label="Toggle theme"></button>
                <button id="mobile-menu-btn" class="text-theme-3 hover:text-theme">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden border-t border-theme bg-theme px-6 py-6 space-y-4 text-[11px] font-bold uppercase tracking-widest text-theme-3">
            <a href="#about"          class="block hover-green transition-colors">About</a>
            <a href="#skills"         class="block hover-green transition-colors">Skills</a>
            <a href="#experience"     class="block hover-green transition-colors">Experience</a>
            <a href="#projects"       class="block hover-green transition-colors">Projects</a>
            <a href="#awards"         class="block hover-green transition-colors">Awards</a>
            <a href="#certifications" class="block hover-green transition-colors">Certifications</a>
            <a href="#contact"        class="block hover-green transition-colors">Contact</a>
            <a href="/admin"          class="block hover-blue transition-colors">Admin</a>
        </div>
    </nav>

    <div class="h-20"></div>

    <script>
        // ── Theme persistence ──────────────────────────────────
        const html = document.documentElement;
        const saved = localStorage.getItem('sdm-theme') || 'dark';
        html.setAttribute('data-theme', saved);

        function applyTheme(theme) {
            html.setAttribute('data-theme', theme);
            localStorage.setItem('sdm-theme', theme);
        }

        function toggleTheme() {
            applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
        }

        document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
        document.getElementById('theme-toggle-mobile').addEventListener('click', toggleTheme);

        // ── Mobile menu ────────────────────────────────────────
        document.getElementById('mobile-menu-btn').addEventListener('click', () => {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });

        // Close mobile menu on nav link click
        document.querySelectorAll('#mobile-menu a').forEach(a => {
            a.addEventListener('click', () => document.getElementById('mobile-menu').classList.add('hidden'));
        });
    </script>
